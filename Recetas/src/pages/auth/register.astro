---
import "@/styles/global.css";
import Navbar from '@/shared/layout/Navbar';
import Footer from '@/shared/layout/Footer';
import RegisterForm from '@/features/auth/components/Login';
import BaseHead from '@/shared/layout/BaseHead.astro';
---

<html lang="es">
  <head>
    <BaseHead title="Registro - ChileBite" description="Únete a la comunidad ChileBite y empieza a compartir tus recetas." />
  </head>
  <body
    class="bg-stone-50 text-gray-800 dark:bg-gray-900 dark:text-gray-200 transition-colors duration-300 min-h-screen flex flex-col"
  >
    <Navbar client:only="react" />

    <main
      class="flex-grow pt-20 flex items-center justify-center px-4 pb-12 relative overflow-hidden bg-[url('https://images.unsplash.com/photo-1555939594-58d7cb561ad1?q=80&w=1920&auto=format&fit=crop')] bg-cover bg-center bg-fixed"
    >
      <!-- Overlay para legibilidad -->
      <div
        class="absolute inset-0 bg-stone-50/70 dark:bg-gray-900/80 backdrop-blur-sm z-0"
      >
      </div>

      <!-- Background decorators to make it premium -->
      <div
        class="absolute -top-40 -left-40 w-96 h-96 bg-[#b08968] rounded-full blur-[100px] opacity-20 hidden dark:block z-0"
      >
      </div>
      <div
        class="absolute top-40 -right-40 w-96 h-96 bg-[#b08968] rounded-full blur-[100px] opacity-20 hidden dark:block z-0"
      >
      </div>

      <div class="relative z-10 w-full flex justify-center">
        <RegisterForm client:only="react" />
      </div>
    </main>

    <Footer />
  </body>
</html>
