---
import "@/styles/global.css";
import Navbar from '@/shared/layout/Navbar';
import Footer from '@/shared/layout/Footer';
import BaseHead from '@/shared/layout/BaseHead.astro';
import AuthErrorHandler from '@/features/auth/components/AuthErrorHandler';
---

<html lang="es">
  <head>
    <BaseHead title="Ajustes - ChileBite" description="Ajustes de cuenta ChileBite." />
  </head>
  <body
    class="bg-stone-50 text-gray-800 dark:bg-gray-900 dark:text-gray-200 transition-colors duration-300 min-h-screen flex flex-col"
  >
    <Navbar client:only="react" />
    <main class="min-h-screen flex items-center justify-center px-4">
      <!-- 
        This page is the landing target for Supabase auth redirects (email change confirmations,
        password recovery errors, etc.). The React component reads the URL hash to determine
        what happened and shows the appropriate message or redirects.
      -->
      <AuthErrorHandler client:only="react" />
    </main>
    <Footer client:only="react" />
  </body>
</html>
