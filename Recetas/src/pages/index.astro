---
import "@/styles/global.css";
import Footer from "@/shared/layout/Footer";
import Navbar from "@/shared/layout/Navbar";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ── Favicon ── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- ── Sitewide Verification ── -->
    <meta
      name="google-site-verification"
      content="9hqIfhGSU9xP42_IWeiyHyFOGAiClu1e_t6JAOJcZWk"
    />

    <!-- ── SEO primario ── -->
    <title>ChileBite – Descubre, Aprende y Comparte</title>
    <meta
      name="description"
      content="ChileBite es la plataforma gastronómica chilena para explorar recetas paso a paso, calcular macronutrientes, descubrir restaurantes y conectar con una comunidad apasionada por la cocina."
    />
    <meta
      name="keywords"
      content="recetas chilenas, cocina chilena, gastronomía Chile, recetas paso a paso, macros cocina, restaurantes Chile, ChileBite"
    />
    <meta name="author" content="Chrystopher Silva, Miguel Escobar" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://chilebite.vercel.app/" />

    <!-- ── Open Graph (Facebook / LinkedIn / WhatsApp) ── -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ChileBite" />
    <meta property="og:url" content="https://chilebite.vercel.app/" />
    <meta
      property="og:title"
      content="ChileBite – Descubre, Aprende y Comparte las Mejores Recetas Chilenas"
    />
    <meta
      property="og:description"
      content="Explora cientos de recetas chilenas, calcula macronutrientes y descubre los mejores restaurantes cerca de ti. ¡Únete a la comunidad ChileBite!"
    />
    <meta
      property="og:image"
      content="https://chilebite.vercel.app/images/Titulo.webp"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CL" />

    <!-- ── Twitter Card ── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="ChileBite – Recetas y Gastronomía Chilena"
    />
    <meta
      name="twitter:description"
      content="Descubre recetas paso a paso, calcula macros y encuentra los mejores locales gastronómicos de Chile."
    />
    <meta
      name="twitter:image"
      content="https://chilebite.vercel.app/images/Titulo.webp"
    />

    <!-- ── Theme & PWA hints ── -->
    <meta name="theme-color" content="#b08968" />

    <!-- ── Google AdSense ── -->
    <meta name="google-adsense-account" content="ca-pub-4855312501819907" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4855312501819907"
      crossorigin="anonymous"></script>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <!-- Evitar FOUC en modo oscuro: inicializar tema antes del render -->
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>

    <style is:global>
      body {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          sans-serif;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
      }

      /* Advanced Scroll Animations (Premium Assembly) */
      .reveal {
        opacity: 0;
        transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }

      .reveal-up {
        transform: translateY(60px);
      }
      .reveal-down {
        transform: translateY(-60px);
      }
      .reveal-left {
        transform: translateX(-100px);
      }
      .reveal-right {
        transform: translateX(100px);
      }
      .reveal-scale {
        transform: scale(0.96) translateZ(0);
        opacity: 0;
        will-change: transform, opacity;
      }

      /* Child Animation (Anti-Jitter Pattern) */
      .reveal-child-right {
        opacity: 0;
        transform: translateX(100px);
        transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }
      .reveal.visible .reveal-child-right {
        opacity: 1;
        transform: translate(0) scale(1);
      }

      .reveal.visible {
        opacity: 1;
        transform: translate(0) scale(1);
      }

      /* Stagger logic via data-delay */
      .reveal.visible[data-delay="100"] {
        transition-delay: 0.1s;
      }
      .reveal.visible[data-delay="200"] {
        transition-delay: 0.2s;
      }
      .reveal.visible[data-delay="300"] {
        transition-delay: 0.3s;
      }
      .reveal.visible[data-delay="400"] {
        transition-delay: 0.4s;
      }
      .reveal.visible[data-delay="500"] {
        transition-delay: 0.5s;
      }

      .parallax-bg {
        background-attachment: fixed;
      }

      .scroll-indicator {
        transition: opacity 0.5s ease;
      }
      .scroll-indicator.hidden-scroll {
        opacity: 0;
        pointer-events: none;
      }
    </style>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        // Intersection Observer for scroll animations (Assembly System)
        const observerOptions = {
          threshold: 0.2,
          rootMargin: "0px 0px -15% 0px",
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            } else {
              entry.target.classList.remove("visible");
            }
          });
        }, observerOptions);

        // Select all elements with reveal classes
        const revealElements = document.querySelectorAll(
          ".reveal, .reveal-up, .reveal-down, .reveal-left, .reveal-right, .reveal-scale",
        );

        revealElements.forEach((el) => {
          // Add the base reveal class if not present
          if (!el.classList.contains("reveal")) {
            el.classList.add("reveal");
          }
          observer.observe(el);
        });

        // Scroll indicator logic
        const scrollIndicator = document.querySelector(".scroll-indicator");
        if (scrollIndicator) {
          window.addEventListener("scroll", () => {
            if (window.scrollY > 100) {
              scrollIndicator.classList.add("hidden-scroll");
            } else {
              scrollIndicator.classList.remove("hidden-scroll");
            }
          });
        }
      });
    </script>
  </head><body
    class="bg-stone-50 dark:bg-gray-900 text-gray-800 dark:text-gray-200 transition-colors duration-300"
  >
    <Navbar client:only="react" />

    <main>
      <!-- Hero Section -->
      <section
        class="relative min-h-[90vh] flex items-center justify-center pt-20 px-4"
      >
        <div
          class="absolute inset-0 bg-[url('/images/Titulo.webp')] bg-cover bg-center parallax-bg"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-40 bg-linear-to-b from-transparent to-zinc-950/90 pointer-events-none"
        >
        </div>

        <div
          class="relative z-10 w-full max-w-4xl text-center reveal-scale visible"
        >
          <div
            class="inline-block mb-6 px-4 py-1.5 rounded-full bg-black/80 backdrop-blur-md border border-white/20 text-white text-sm font-semibold tracking-wide uppercase"
          >
            Una experiencia gastronómica
          </div>
          <h1
            class="text-5xl md:text-7xl font-black text-white tracking-tight mb-8"
          >
            Bienvenido a <span class="text-[#b08968]">ChileBite</span>
          </h1>
          <p
            class="text-lg md:text-xl text-gray-200 font-medium leading-relaxed max-w-3xl mx-auto backdrop-blur-sm bg-black/70 p-6 rounded-3xl border border-white/10"
          >
            Somos Chrystopher Silva y Miguel Escobar. Creamos esta plataforma
            para que descubras, compartas y disfrutes las mejores recetas y
            locales cerca de ti.
          </p>
        </div>

        <!-- Scroll Indicator -->
        <div
          class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce scroll-indicator z-20 cursor-pointer"
          onclick="window.scrollBy({top: window.innerHeight, behavior: 'smooth'})"
        >
          <i
            class="fa-solid fa-chevron-down text-white/50 text-4xl hover:text-white/80 transition-colors"
          ></i>
        </div>
      </section>

      <!-- Propuesta de Valor -->
      <section
        class="min-h-screen flex flex-col justify-center py-24 px-4 bg-gray-900 relative"
      >
        <div class="max-w-7xl mx-auto w-full">
          <div class="text-center mb-16 reveal-up">
            <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">
              ¿Qué te ofrecemos?
            </h2>
            <p class="text-lg text-gray-400 max-w-2xl mx-auto">
              Todo lo que necesitas para tu próxima aventura culinaria, en un
              solo lugar.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div
              class="p-10 rounded-[2.5rem] bg-gray-800 border-gray-700 reveal-left hover:-translate-y-2 transition-transform duration-300"
              data-delay="100"
            >
              <div
                class="w-16 h-16 rounded-2xl bg-[#b08968]/20 flex items-center justify-center mb-6"
              >
                <i class="fa-solid fa-utensils text-2xl text-[#b08968]"></i>
              </div>
              <h3 class="text-2xl font-bold mb-4 text-white">
                Aprende a Cocinar
              </h3>
              <p class="text-gray-300 leading-relaxed">
                Explora un catálogo extenso de recetas detalladas paso a paso.
                Desde platos tradicionales chilenos hasta innovación
                gastronómica, apoyado con nuestros videotutoriales exclusivos.
              </p>
            </div>

            <div
              class="p-10 rounded-[2.5rem] bg-gray-800 border-gray-700 reveal-right hover:-translate-y-2 transition-transform duration-300"
              data-delay="300"
            >
              <div
                class="w-16 h-16 rounded-2xl bg-[#b08968]/20 flex items-center justify-center mb-6"
              >
                <i class="fa-solid fa-store text-2xl text-[#b08968]"></i>
              </div>
              <h3 class="text-2xl font-bold mb-4 text-white">
                Descubre Locales
              </h3>
              <p class="text-gray-300 leading-relaxed">
                Encuentra los mejores restaurantes y picadas en tu zona. Filtra
                por tus preferencias y sal a disfrutar de la mejor gastronomía
                en tu ciudad.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Feature Split -->
      <section
        class="min-h-screen flex flex-col justify-center py-24 px-4 bg-gradient-to-b from-gray-900 to-gray-800 overflow-hidden"
      >
        <div
          class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center w-full"
        >
          <div class="reveal-left pr-0 md:pr-10">
            <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">
              Una galería hecha <span class="text-[#b08968]">a tu medida</span>
            </h2>
            <p class="text-lg text-gray-300 leading-relaxed mb-8">
              Disfruta de una interfaz agradable y fácil de usar, diseñada para
              que encuentres lo que buscas sin complicaciones. Filtra por país,
              dificultad, cantidad de porciones y más. Guarda tus favoritas en
              un solo clic.
            </p>
            <a
              href="/recipes"
              class="inline-flex items-center space-x-2 px-8 py-4 rounded-xl bg-[#b08968] text-white font-bold hover:bg-[#9a7657] transition-colors shadow-lg shadow-[#b08968]/30"
            >
              <span>Explorar Recetas</span>
              <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
          <div class="reveal w-full relative flex items-center justify-center">
            <!-- Animated Inner Content -->
            <div
              class="reveal-child-right w-full flex items-center justify-center group relative"
            >
              <!-- Fixed Background Decoration -->
              <div
                class="absolute -inset-10 rounded-[3.5rem] bg-linear-to-tr from-[#b08968]/30 via-[#b08968]/10 to-transparent border border-[#b08968]/20 backdrop-blur-md -z-10 animate-pulse"
              >
              </div>
              <img
                src="/images/Sitio.png"
                alt="Interfaz Galería"
                class="relative rounded-3xl shadow-2xl border border-gray-700 mx-auto w-full max-w-lg object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Comunidad -->
      <section
        class="min-h-screen flex flex-col justify-center py-24 px-4 bg-gradient-to-b from-gray-800 to-black"
      >
        <div class="max-w-4xl mx-auto text-center reveal-up w-full">
          <div
            class="inline-block mb-6 px-4 py-1.5 rounded-full bg-gray-800 text-[#b08968] font-bold tracking-wide uppercase text-sm"
          >
            Comunidad ChileBite
          </div>
          <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-8">
            Conecta, Guarda y Comparte
          </h2>
          <p class="text-lg text-gray-300 leading-relaxed mb-12">
            Únete a otros entusiastas de la comida. Participa creando tu perfil,
            guarda tus recetas predilectas, y da 'me gusta' para ayudar a
            posicionar los mejores platos en la comunidad.
          </p>
          <div class="reveal-scale">
            <img
              src="/images/Carta.png"
              alt="Carta de recetas"
              class="rounded-3xl shadow-2xl mx-auto w-full max-w-xl object-contain border border-gray-800"
            
              />
          </div>
        </div>
      </section>

      <!-- Negocios CTA -->
      <section
        class="min-h-screen flex flex-col justify-center py-24 px-4 bg-black text-white relative overflow-hidden"
      >
        <!-- Textura de fondo -->
        <div
          class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/food.png')]"
        >
        </div>
        
        <!-- Overlay degradado para fundir el borde superior sin lineas rectas -->
        <div class="absolute top-0 inset-x-0 h-48 bg-gradient-to-b from-black via-black/80 to-transparent pointer-events-none"></div>
        <div
          class="absolute -top-80 -right-80 w-160 h-160 bg-[#b08968] opacity-10 rounded-full blur-[120px] group-hover:opacity-15 transition-opacity duration-700"
        >
        </div>

        <div class="max-w-4xl mx-auto text-center relative z-10 reveal-up">
          <h2 class="text-4xl md:text-5xl font-extrabold mb-6">
            ¿Deseas llegar a más clientes?
          </h2>
          <p class="text-xl text-gray-300 mb-10 leading-relaxed">
            Si eres dueño de un restaurante, pequeña picada o emprendimiento
            gastronómico, únete a nuestra red. Crea un perfil de <span
              class="text-[#b08968] font-bold">Restaurante</span
            > y gestiona tu visibilidad sin costo.
          </p>
          <a
            href="/auth/register"
            class="inline-block px-10 py-5 rounded-2xl bg-white text-gray-900 font-extrabold text-lg hover:scale-105 transition-transform shadow-[0_0_40px_rgba(255,255,255,0.3)]"
          >
            Registra tu Local Hoy
          </a>
        </div>
      </section>
    </main>

    <Footer client:visible />
  </body>
</html>
