---
import "@/styles/global.css";
import Footer from '@/shared/layout/Footer';
import Navbar from '@/shared/layout/Navbar';
import BaseHead from '@/shared/layout/BaseHead.astro';
import RecetaDetalle from '@/features/recipes/components/RecipeDetail';
import CommentSection from '@/features/comments/components/CommentSection';
import AffiliateCarousel from '@/shared/ui/AffiliateCarousel';

import { supabase } from '@/lib/supabaseClient';

export async function getStaticPaths() {
  try {
    const { data: recetas, error } = await supabase
      .from('core_receta')
      .select('id, nombre');
      
    if (error) throw new Error(error.message);

    if (!recetas || recetas.length === 0) {
      return [{ params: { id: "1" }, props: { nombre: "Detalle de Receta" } }]; 
    }
    
    return recetas.map((receta) => ({
      params: { id: receta.id.toString() },
      props: { nombre: receta.nombre },
    }));
  } catch (err) {
    console.error("Error obteniendo rutas estáticas (getStaticPaths) desde Supabase:", err);
    return [{ params: { id: "1" }, props: { nombre: "Detalle de Receta" } }];
  }
}

const { id } = Astro.params;
const { nombre } = Astro.props;
---

<html lang="es">
  <head>
    <BaseHead 
      title={`${nombre} – ChileBite`} 
      description={`Aprende a preparar ${nombre} paso a paso con nuestra receta detallada.`}
    />
  </head>
<Navbar client:only="react" />
  <body class="bg-[#f7f7f6] dark:bg-[#0f1115] font-['Inter'] transition-colors duration-300 antialiased min-h-screen">
    <!-- Wrapper normal debajo del navbar -->
    <main class="mt-20 flex-1 relative z-10 w-full">
        <RecetaDetalle idReceta={id} client:only="react" />
        <div className="max-w-[1400px] mx-auto w-full px-4 lg:px-8">
            <AffiliateCarousel client:only="react" />
        </div>
        <div class="max-w-[1400px] mx-auto w-full px-4 lg:px-8 pb-16">
            <CommentSection recipeId={id} client:only="react" />
        </div>
    </main>
  </body>
  <Footer/>
</html>
