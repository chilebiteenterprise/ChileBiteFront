---
import "../styles/global.css";
import Navbar from "../layouts/Navbar.jsx";
import Footer from "../layouts/Footer.jsx";
import RegisterForm from "../components/Formularios/Login";

// Función que será pasada al formulario para abrir login
let abrirLoginNavbar;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Registro</title>
  </head>
  <body>
    <Navbar client:only="react" on:setAbrirLogin={(e) => abrirLoginNavbar = e.detail} />

    <div class="pt-20">
      <RegisterForm
        client:only="react"
        abrirLogin={() => abrirLoginNavbar && abrirLoginNavbar()}
      />
    </div>

    <Footer />
  </body>
</html>
