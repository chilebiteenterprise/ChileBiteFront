---
import "@/styles/global.css";
import Footer from '@/shared/layout/Footer';
import Navbar from '@/shared/layout/Navbar';
import ChileMap from '@/features/ruta/components/ChileMap';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Sort for map route (chronological)
const mapPosts = [...posts].sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>La Ruta del Sabor | ChileBite</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>

  <body class="bg-stone-50 dark:bg-gray-950 text-gray-800 dark:text-gray-200 transition-colors duration-300">
    <Navbar client:only="react" />

    <main class="pt-24 pb-16">
      {/* Header Section */}
      <section class="max-w-7xl mx-auto px-4 mb-16">
        <div class="text-center mb-12">
          <div class="inline-block mb-4 px-4 py-1.5 rounded-full bg-[#b08968]/20 border border-[#b08968]/30 text-[#b08968] text-sm font-bold tracking-widest uppercase">
            Aventura Gastronómica
          </div>
          <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-6">
            La Ruta del <span class="text-[#b08968]">Sabor</span>
          </h1>
          <p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
            Acompaña a nuestro creador de videos en su travesía por Chile, descubriendo los mejores locales, recetas y paisajes de nuestra tierra.
          </p>
        </div>

        {/* Map Container */}
        <div class="scroll-reveal visible">
          <ChileMap client:only="react" posts={mapPosts} />
        </div>
      </section>

      {/* Posts Grid */}
      <section class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between items-end mb-10">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Últimas Paradas</h2>
            <div class="h-1 w-20 bg-[#b08968] rounded-full"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <article class="group bg-white dark:bg-gray-900/50 backdrop-blur-sm border border-gray-200 dark:border-white/5 rounded-[2rem] overflow-hidden hover:border-[#b08968]/30 transition-all duration-300 flex flex-col h-full hover:-translate-y-2">
              <a href={`/blog/${post.slug}`} class="relative aspect-[16/10] overflow-hidden">
                <img 
                  src={post.data.heroImage || '/placeholder.webp'} 
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-950/80 to-transparent"></div>
                <div class="absolute bottom-4 left-6">
                  <span class="px-3 py-1 bg-[#b08968] text-white text-[10px] font-black rounded-full uppercase tracking-tighter">
                    {post.data.location.label}
                  </span>
                </div>
              </a>
              
              <div class="p-8 flex flex-col flex-grow">
                <time class="text-xs text-[#b08968] font-bold uppercase mb-3 tracking-widest">
                  {new Intl.DateTimeFormat('es-CL', { dateStyle: 'long' }).format(post.data.pubDate)}
                </time>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 group-hover:text-[#b08968] transition-colors leading-tight">
                  {post.data.title}
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed mb-6 flex-grow line-clamp-3">
                  {post.data.description}
                </p>
                <a 
                  href={`/blog/${post.slug}`} 
                  class="inline-flex items-center space-x-2 text-gray-900 dark:text-white font-black hover:text-[#b08968] transition-colors group/link"
                >
                  <span class="text-sm">Ver Video completo</span>
                  <i class="fa-solid fa-arrow-right text-xs group-hover/link:translate-x-1 transition-transform"></i>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer client:visible />
  </body>
</html>

<style is:global>
  ::selection {
    background: #b08968;
    color: white;
  }
</style>
